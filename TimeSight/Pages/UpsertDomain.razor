@using TimeSight.repositories

@page "/domains/create"
@page "/domains/edit/{id:guid}"

@attribute [Authorize]

@inject NavigationManager navigationManager
@inject IDomainRepository domainRepository

<PageTitle>@(Id != null ? "Edit Domain" : "New Domain") — TimeSight</PageTitle>

@if (domain != null)
{
    <div class="form-card">
        <h2 class="form-card-title">@(Id != null ? "Edit domain" : "New domain")</h2>

        <EditForm Model="domain" OnValidSubmit="Submit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-group">
                <label for="domain-name">Name</label>
                <InputText class="form-control" id="domain-name" placeholder="e.g. Work, Health, Personal…" @bind-Value="domain.Name" />
                <ValidationMessage for="() => domain.Name" />
            </div>

            <div class="form-group">
                <label for="domain-color">Color</label>
                <div class="domain-color-picker-wrap">
                    <input type="color" id="domain-color" class="domain-color-input"
                           value="@(domain.Color ?? "#6366f1")"
                           @oninput="e => domain.Color = e.Value?.ToString()" />
                    <span class="domain-tag" style="--tag-color:@(domain.Color ?? "#6366f1")">
                        @domain.Name
                    </span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    @(Id != null ? "Save changes" : "Create domain")
                </button>
                <button type="button" class="btn btn-ghost" @onclick='() => navigationManager.NavigateTo("/domains")'>
                    Cancel
                </button>
            </div>
        </EditForm>
    </div>
}
@code {
    [CascadingParameter(Name = "UserId")]
    public Guid? UserId { get; set; }

    [Parameter]
    public Guid? Id { get; set; }

    private Domain? domain;

    public async Task Submit()
    {
        ArgumentNullException.ThrowIfNull(domain);

        if (Id != null)
        {
            domain = await domainRepository.UpdateDomainAsync(domain);
        }
        else
        {
            domain = await domainRepository.CreateDomainAsync(domain);
        }
        navigationManager.NavigateTo(uri: "/domains");
    }

    protected override async Task OnParametersSetAsync()
    {
        if (UserId == null)
            throw new ArgumentException("UserId est null");


        if (Id != null)
        {
            domain = await domainRepository.GetDomainAsync(Id.Value);
        }
        else
        {
            domain = new Domain() { UserId = (Guid)UserId, Name = "" };
        }
        await base.OnParametersSetAsync();
    }

}
