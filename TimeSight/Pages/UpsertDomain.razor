@using TimeSight.repositories

@page "/domains/create"
@page "/domains/edit/{id:guid}"

@attribute [Authorize]

@inject NavigationManager navigationManager
@inject IDomainRepository domainRepository

<PageTitle>@(Id != null ? "Edit Domain" : "New Domain") — TimeSight</PageTitle>

@if (domain != null)
{
    <div class="card" style="max-width:460px">
        <div class="card-body p-4">
            <h2 class="card-title border-bottom pb-3 mb-4">@(Id != null ? "Edit domain" : "New domain")</h2>

            <EditForm Model="domain" OnValidSubmit="Submit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label" for="domain-name">Name</label>
                    <InputText class="form-control" id="domain-name" placeholder="e.g. Work, Health, Personal…"
                               @bind-Value="domain.Name" />
                    <ValidationMessage for="() => domain.Name" />
                </div>

                <div class="mb-3">
                    <label class="form-label" for="domain-description">Description</label>
                    <InputTextArea class="form-control" id="domain-description" rows="8" placeholder="Markdown supported…"
                                   @bind-Value="domain.Description" />
                </div>

                <div class="mb-3">
                    <label class="form-label" for="domain-color">Color</label>
                    <div class="domain-color-picker-wrap">
                        <input type="color" id="domain-color" class="domain-color-input"
                               value="@(domain.Color ?? "#6366f1")" @oninput="e => domain.Color = e.Value?.ToString()" />
                        <span class="domain-tag" style="--tag-color:@(domain.Color ?? "#6366f1")">
                            @domain.Name
                        </span>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4 pt-3 border-top">
                    <button type="submit" class="btn btn-primary">
                        @(Id != null ? "Save changes" : "Create domain")
                    </button>
                    <button type="button" class="btn btn-outline-secondary"
                            @onclick='() => navigationManager.NavigateToRelative("domains")'>
                        Cancel
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}
@code {
    [CascadingParameter(Name = "UserId")]
    public Guid? UserId { get; set; }

    [Parameter]
    public Guid? Id { get; set; }

    private Domain? domain;

    public async Task Submit()
    {
        ArgumentNullException.ThrowIfNull(domain);

        if (Id != null)
        {
            domain = await domainRepository.UpdateDomainAsync(domain);
        }
        else
        {
            domain = await domainRepository.CreateDomainAsync(domain);
        }
        navigationManager.NavigateToRelative("domains");
    }

    protected override async Task OnParametersSetAsync()
    {
        if (UserId == null)
            throw new ArgumentException("UserId est null");

        if (Id != null)
        {
            domain = await domainRepository.GetDomainAsync(Id.Value);
        }
        else
        {
            domain = new Domain() { UserId = (Guid)UserId, Name = "" };
        }
        await base.OnParametersSetAsync();
    }
}
