@using System.Security.Claims
@using TimeSight.Services
@using TimeSight.repositories

@page "/"

@attribute [Authorize]
@implements IDisposable
@inject IDomainRepository domainRepository;
@inject OrderChoresService orderChoresService;
@inject ChoreService choreService;
@inject ChoreDomainService choreDomainService;
@inject WorkspaceState workspaceState;
@inject UrgencyThresholdService urgencyThresholdService;

<PageTitle>Tasks — TimeSight</PageTitle>

@if (workspaceState.CurrentWorkspace == null)
{
    <div class="text-muted mt-4">Select a workspace from the sidebar to view tasks.</div>
}
else
{

    <div class="d-flex align-items-start justify-content-between gap-3 mb-4">
        <div>
            <h1 class="page-title">Tasks</h1>
            <p class="text-muted small mb-0">@orderedChores.Count task@(orderedChores.Count == 1 ? "" :
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               "s")@(IsFiltered ? $" of {choresDic.Count}" : "")</p>
            </div>
            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                <div class="d-flex align-items-center gap-2">
                    <label class="form-label mb-0 small text-muted" for="urgency-threshold">Urgent within</label>
                    <select id="urgency-threshold" class="form-select form-select-sm" style="width:auto"
                            value="@UrgencyThresholdDays" @onchange="e => UrgencyThresholdDays = int.Parse(e.Value!.ToString()!)">
                        @foreach (var days in Chore.EmergencyThresholdOptionsDays)
                        {
                            <option value="@days">@UrgencyThresholdLabel(days)</option>
                        }
                    </select>
                </div>
                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="Order" disabled="@_isSorting">
                    @if (_isSorting)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    else
                    {
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <line x1="3" y1="6" x2="21" y2="6" />
                            <line x1="8" y1="12" x2="21" y2="12" />
                            <line x1="13" y1="18" x2="21" y2="18" />
                        </svg>
                    }
                    @(_isSorting ? "Sorting…" : "Sort")
                </button>
                <button type="button" class="btn btn-primary btn-sm" @onclick="AddChore" disabled="@_isAdding">
                    @if (_isAdding)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    else
                    {
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                             stroke-linecap="round">
                            <line x1="12" y1="5" x2="12" y2="19" />
                            <line x1="5" y1="12" x2="19" y2="12" />
                        </svg>
                    }
                    @(_isAdding ? "Adding…" : "New task")
                </button>
            </div>
        </div>

        <div class="filter-bar">
            <div class="filter-row">
                <button class="filter-pill @(showDone ? "active" : "")" @onclick="ToggleShowDone">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                         stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12" />
                    </svg>
                    Completed
                </button>

                <button class="filter-pill @(subtasksOnly ? "active" : "")" @onclick="ToggleSubtasksOnly">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="9 18 15 12 9 6" />
                    </svg>
                    Subtasks only
                </button>
            </div>

            <div class="filter-row">
                @foreach (var domain in domains)
                {
                    var isActive = selectedDomainIds.Contains(domain.Id!.Value);
                    <button class="filter-pill @(isActive ? "active" : "")" style="--pill-color:@(domain.Color ?? "#6366f1")"
                            @onclick="() => ToggleDomainFilter(domain.Id!.Value)">
                        <span class="filter-pill-dot"></span>
                        @domain.Name
                    </button>
                }
            </div>

            @if (IsFiltered)
            {
                <button class="filter-clear" @onclick="ClearFilters">Clear</button>
            }
        </div>

        <ul class="chores-list">
            @foreach (var (chore, depth) in orderedChores)
            {
                <ChoreComponent @key="chore.Id" Chore="chore" OnDelete="HandleDelete" allDomains="domains"
                                OnIsDoneChanged="StateHasChanged" StartEditing="chore.Id == _newlyAddedChoreId" AllChores="choresDic.Values"
                                Depth="depth" OnHierarchyChanged="RebuildOrderedChores" OnCreateSubtask="HandleCreateSubtask">
                </ChoreComponent>
            }
        </ul>

    }

@code {
    [CascadingParameter(Name = "UserId")]
    public Guid? UserId { get; set; }

    private List<Domain> domains = [];

    private IDictionary<Guid, Chore> choresDic = new Dictionary<Guid, Chore>();

    private Guid? _newlyAddedChoreId;
    private List<Guid>? _sortedChoreIds;

    private bool showDone = false;
    private bool subtasksOnly = false;
    private HashSet<Guid> selectedDomainIds = [];

    private bool _isAdding;
    private bool _isSorting;
    private bool IsFiltered => showDone || subtasksOnly || selectedDomainIds.Count > 0;

    private List<(Chore chore, int depth)> orderedChores = [];

    private int UrgencyThresholdDays
    {
        get => Chore.DaysBeforeEmergencyStart;
        set
        {
            urgencyThresholdService.SetThresholdDays(value);
            RebuildOrderedChores();
        }
    }

    private static string UrgencyThresholdLabel(int days) => days switch
    {
        7 => "1 week",
        14 => "2 weeks",
        30 => "1 month",
        60 => "2 months",
        90 => "3 months",
        _ => $"{days} days"
    };

    protected override async Task OnParametersSetAsync()
    {
        workspaceState.OnChanged += OnWorkspaceChanged;
        await LoadData();
        await base.OnParametersSetAsync();
    }

    private async void OnWorkspaceChanged()
    {
        await LoadData();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadData()
    {
        if (workspaceState.CurrentWorkspace?.Id is Guid wsId)
        {
            var choresTask = choreService.GetChoresAsync(wsId);
            var domainsTask = domainRepository.GetDomainsAsync(wsId);
            await Task.WhenAll(choresTask, domainsTask);
            choresDic = choresTask.Result;
            domains = domainsTask.Result;
            await choreService.ResetExpiredRecurringChoresAsync(choresDic.Values, domains);
        }
        else
        {
            choresDic = new Dictionary<Guid, Chore>();
            domains = [];
        }
        _newlyAddedChoreId = null;
        _sortedChoreIds = null;
        selectedDomainIds.Clear();
        RebuildOrderedChores();
    }

    public void Dispose() => workspaceState.OnChanged -= OnWorkspaceChanged;

    private void RebuildOrderedChores()
    {
        var result = new List<(Chore, int)>();

        var orderedRoots = GetRoots().Values;
        if (_sortedChoreIds != null)
            orderedRoots = orderedRoots
                .OrderBy(c => _sortedChoreIds.IndexOf(c.Id))
                .ToList();

        foreach (Chore root in orderedRoots)
            AppendWithChildren(root, 0, result);
        orderedChores = result;
    }

    private void AppendWithChildren(Chore chore, int depth, List<(Chore, int)> result)
    {
        result.Add((chore, depth));
        var visibleChildren = showDone ? chore.Children : chore.Children.Where(c => !c.IsDone);
        foreach (var child in visibleChildren)
            AppendWithChildren(child, depth + 1, result);
    }



    private async Task HandleDelete(Chore chore)
    {
        ArgumentNullException.ThrowIfNull(chore);
        await choreService.DeleteChoreAsync(chore);
        choresDic.Remove(chore.Id);
        RebuildOrderedChores();
    }

    private async Task AddChore()
    {
        _isAdding = true;
        try
        {
            var wsId = workspaceState.CurrentWorkspace?.Id
                ?? throw new InvalidOperationException("No workspace selected");
            Chore chore = await choreService.CreateChoreAsync(UserId!.Value, wsId);
            if (selectedDomainIds.Count > 0)
            {
                var selectedDomains = domains.Where(d => d.Id.HasValue && selectedDomainIds.Contains(d.Id.Value));
                await Task.WhenAll(selectedDomains.Select(d => choreDomainService.AddLink(chore, d)));
            }
            _newlyAddedChoreId = chore.Id;
            choresDic.Add(chore.Id, chore);
            RebuildOrderedChores();
        }
        finally
        {
            _isAdding = false;
        }
    }

    private async Task HandleCreateSubtask(Chore parent)
    {
        var wsId = workspaceState.CurrentWorkspace?.Id
            ?? throw new InvalidOperationException("No workspace selected");
        Chore chore = await choreService.CreateChoreAsync(UserId!.Value, wsId);
        await choreService.SetParent(chore, parent, domains);
        _newlyAddedChoreId = chore.Id;
        choresDic.Add(chore.Id, chore);
        RebuildOrderedChores();
    }

    private void ToggleShowDone()
    {
        showDone = !showDone;
        _newlyAddedChoreId = null;
        _sortedChoreIds = null;
        RebuildOrderedChores();
    }

    private void ToggleDomainFilter(Guid domainId)
    {
        if (!selectedDomainIds.Remove(domainId))
            selectedDomainIds.Add(domainId);
        _newlyAddedChoreId = null;
        _sortedChoreIds = null;
        RebuildOrderedChores();
    }

    private void ToggleSubtasksOnly()
    {
        subtasksOnly = !subtasksOnly;
        _newlyAddedChoreId = null;
        _sortedChoreIds = null;
        RebuildOrderedChores();
    }

    private void ClearFilters()
    {
        showDone = false;
        subtasksOnly = false;
        selectedDomainIds.Clear();
        _newlyAddedChoreId = null;
        _sortedChoreIds = null;
        RebuildOrderedChores();
    }
    private IDictionary<Guid, Chore> GetFilteredChoresDic()
    {

        var result = choresDic.AsEnumerable();
        if (!showDone)
            result = result.Where(c => !c.Value.IsDone);
        if (selectedDomainIds.Count > 0)
            result = result.Where(c => c.Value.ChoreDomains.Any(cd => selectedDomainIds.Contains(cd.DomainId)));
        if (subtasksOnly)
            result = result
            .Where(c => c.Value.Children.Count == 0);
        return result.ToDictionary();
    }
    private IDictionary<Guid, Chore> GetRoots()
    {
        IDictionary<Guid, Chore> filteredChoresDic = GetFilteredChoresDic();
        return filteredChoresDic.Where(c =>
        c.Value.ParentChoreId == null ||
        !filteredChoresDic.ContainsKey(c.Value.ParentChoreId.Value)).ToDictionary();
    }
    private async Task Order()
    {
        _isSorting = true;
        try
        {
            _sortedChoreIds = orderChoresService.OrderChores(GetRoots(), domains);

            var wsId = workspaceState.CurrentWorkspace?.Id
                ?? throw new InvalidOperationException("No workspace selected");

            var domainsWithoutTasks = domains
                .Where(d => !choresDic.Values.Any(c =>
                    c.ParentChoreId == null &&
                    !c.IsDone &&
                    c.ChoreDomains.Any(cd => cd.DomainId == d.Id)))
                .ToList();

            foreach (var domain in domainsWithoutTasks)
            {
                var chore = await choreService.CreateChoreAsync(
                    UserId!.Value, wsId, $"Plan tasks for {domain.Name}");
                await choreDomainService.AddLink(chore, domain);
                choresDic.Add(chore.Id, chore);
                _sortedChoreIds.Add(chore.Id);
            }

            RebuildOrderedChores();
        }
        finally
        {
            _isSorting = false;
        }
    }
}
