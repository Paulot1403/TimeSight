@using System.Security.Claims
@using TimeSight.Services
@using TimeSight.repositories

@page "/"

@attribute [Authorize]
@inject IChoreRepository choreRepository;
@inject IDomainRepository domainRepository;
@inject OrderChoresService orderChoresService;

<PageTitle>Tasks — TimeSight</PageTitle>

<div class="d-flex align-items-start justify-content-between gap-3 mb-4">
    <div>
        <h1 class="page-title">Tasks</h1>
        <p class="text-muted small mb-0">@orderedChores.Count task@(orderedChores.Count == 1 ? "" :
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               "s")@(IsFiltered ? $" of {chores.Count}" : "")</p>
        </div>
        <div class="d-flex align-items-center gap-2 flex-shrink-0">
            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="Order">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <line x1="3" y1="6" x2="21" y2="6" />
                    <line x1="8" y1="12" x2="21" y2="12" />
                    <line x1="13" y1="18" x2="21" y2="18" />
                </svg>
                Sort
            </button>
            <button type="button" class="btn btn-primary btn-sm" @onclick="AddChore">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                     stroke-linecap="round">
                    <line x1="12" y1="5" x2="12" y2="19" />
                    <line x1="5" y1="12" x2="19" y2="12" />
                </svg>
                New task
            </button>
        </div>
    </div>

    <div class="filter-bar">
        <button class="filter-pill @(showDone ? "active" : "")" @onclick="ToggleShowDone">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                 stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
            </svg>
            Completed
        </button>

        <button class="filter-pill @(subtasksOnly ? "active" : "")" @onclick="ToggleSubtasksOnly">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6" />
            </svg>
            Subtasks only
        </button>

        @foreach (var domain in domains)
        {
            var isActive = selectedDomainIds.Contains(domain.Id!.Value);
            <button class="filter-pill @(isActive ? "active" : "")" style="--pill-color:@(domain.Color ?? "#6366f1")"
                    @onclick="() => ToggleDomainFilter(domain.Id!.Value)">
                <span class="filter-pill-dot"></span>
                @domain.Name
            </button>
        }

        @if (IsFiltered)
        {
            <button class="filter-clear" @onclick="ClearFilters">Clear</button>
        }
    </div>

    <ul class="chores-list">
        @foreach (var (chore, depth) in orderedChores)
        {
            <ChoreComponent Chore="chore" OnDelete="HandleDelete" allDomains="domains" OnIsDoneChanged="StateHasChanged"
                            StartEditing="chore.Id == _newlyAddedChoreId" AllChores="chores" Depth="depth"
                            OnHierarchyChanged="StateHasChanged">
            </ChoreComponent>
        }
    </ul>

@code {
    [CascadingParameter(Name = "UserId")]
    public Guid? UserId { get; set; }

    private List<Domain> domains = [];
    private List<Chore> chores = [];

    private Guid? _newlyAddedChoreId;
    private List<Guid>? _sortedChoreIds;

    private bool showDone = false;
    private bool subtasksOnly = false;
    private HashSet<Guid> selectedDomainIds = [];

    private bool IsFiltered => showDone || subtasksOnly || selectedDomainIds.Count > 0;

    private IEnumerable<Chore> filteredChores
    {
        get
        {
            var result = chores.AsEnumerable();
            if (!showDone)
                result = result.Where(c => !c.IsDone);
            if (selectedDomainIds.Count > 0)
                result = result.Where(c => c.ChoreDomains.Any(cd => selectedDomainIds.Contains(cd.DomainId)));
            if (subtasksOnly)
                result = result
                    .Where(c => !chores.Any(c2 => c2.ParentChoreId == c.Id));
            return result;
        }
    }
    private IEnumerable<Chore> roots
    {
        get
        {
            var filteredChoresList = filteredChores.ToList();

            var filteredIds = filteredChoresList.Select(c => c.Id!.Value).ToHashSet();
            return filteredChoresList.Where(c =>
                c.ParentChoreId == null ||
                !filteredIds.Contains(c.ParentChoreId.Value));
        }
    }

    private List<(Chore chore, int depth)> orderedChores = [];

    private void RebuildOrderedChores()
    {
        var result = new List<(Chore, int)>();

        var orderedRoots = roots;
        if (_sortedChoreIds != null)
            orderedRoots = orderedRoots.OrderBy(c => _sortedChoreIds.IndexOf(c.Id!.Value));

        foreach (var root in orderedRoots)
            AppendWithChildren(root, 0, result);
        orderedChores = result;
    }

    private void AppendWithChildren(Chore chore, int depth, List<(Chore, int)> result)
    {
        result.Add((chore, depth));
        foreach (var child in chores.Where(c => c.ParentChoreId == chore.Id))
            AppendWithChildren(child, depth + 1, result);
    }

    protected override async Task OnParametersSetAsync()
    {
        chores = await choreRepository.GetChoresAsync();
        domains = await domainRepository.GetDomainsAsync();
        RebuildOrderedChores();
        await base.OnInitializedAsync();
    }

    public async Task HandleDelete(Chore chore)
    {
        ArgumentNullException.ThrowIfNull(chore.Id);
        await choreRepository.DeleteChoreAsync(chore.Id.Value);
        chores.Remove(chore);
        RebuildOrderedChores();
    }

    public async Task AddChore()
    {
        Chore chore = new Chore()
        {
            UserId = UserId!.Value,
            Name = "New task"
        };
        chore = await choreRepository.CreateChoreAsync(chore);
        _newlyAddedChoreId = chore.Id;
        chores.Add(chore);
        RebuildOrderedChores();
    }

    private void ToggleShowDone()
    {
        showDone = !showDone;
        _newlyAddedChoreId = null;
        _sortedChoreIds = null;
        RebuildOrderedChores();
    }

    private void ToggleDomainFilter(Guid domainId)
    {
        if (!selectedDomainIds.Remove(domainId))
            selectedDomainIds.Add(domainId);
        _newlyAddedChoreId = null;
        _sortedChoreIds = null;
        RebuildOrderedChores();
    }

    private void ToggleSubtasksOnly()
    {
        subtasksOnly = !subtasksOnly;
        _newlyAddedChoreId = null;
        _sortedChoreIds = null;
        RebuildOrderedChores();
    }

    private void ClearFilters()
    {
        showDone = false;
        subtasksOnly = false;
        selectedDomainIds.Clear();
        _newlyAddedChoreId = null;
        _sortedChoreIds = null;
        RebuildOrderedChores();
    }

    public void Order()
    {
        _sortedChoreIds = orderChoresService.OrderChores(roots.ToList(), domains);
        RebuildOrderedChores();
    }
}
