@using TimeSight.repositories
@using System.Security.Claims

@page "/"

@attribute [Authorize]
@inject IChoreRepository choreRepository;
@inject IDomainRepository domainRepository;

<PageTitle>Tasks — TimeSight</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Tasks</h1>
        <p class="page-subtitle">@chores.Count task@(chores.Count == 1 ? "" : "s")</p>
    </div>
    <div class="page-actions">
        <button type="button" class="btn btn-ghost" @onclick="Order">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="3" y1="6" x2="21" y2="6"/>
                <line x1="8" y1="12" x2="21" y2="12"/>
                <line x1="13" y1="18" x2="21" y2="18"/>
            </svg>
            Sort
        </button>
        <button type="button" class="btn btn-primary" @onclick="AddChore">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            New task
        </button>
    </div>
</div>

<ul class="chores-list">
    @foreach (var chore in chores)
    {
        <ChoreComponent Chore="chore" OnDelete="HandleDelete" allDomains="domains"></ChoreComponent>
    }
</ul>

@code {
    [CascadingParameter(Name = "UserId")]
    public Guid? UserId { get; set; }

    private ICollection<Domain> domains = [];
    private ICollection<Chore> chores = [];
    private ICollection<ChoreDomain> choreDomains = [];


    protected override async Task OnParametersSetAsync()
    {
        chores = await choreRepository.GetChoresAsync();
        domains = await domainRepository.GetDomainsAsync();
        await base.OnInitializedAsync();
    }
    public async Task HandleDelete(Chore chore)
    {
        ArgumentNullException.ThrowIfNull(chore.Id);
        await choreRepository.DeleteChoreAsync(chore.Id.Value);
        chores.Remove(chore);
    }

    public async Task AddChore()
    {
        Chore chore = new Chore()
        {
            UserId = UserId.Value,
            Name = "Choose"
        };
        chore = await choreRepository.CreateChoreAsync(chore);
        chores.Add(chore);
    }


    public void Order()
    { }

}
