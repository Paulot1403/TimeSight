@page "/calendar"
@attribute [Authorize]
@implements IDisposable
@using TimeSight.Services
@using TimeSight.repositories
@inject ChoreService choreService
@inject IDomainRepository domainRepository
@inject WorkspaceState workspaceState

<PageTitle>Calendar &#x2013; TimeSight</PageTitle>

@if (_undoChore != null)
{
    <div class="calendar-undo-toast">
        <span>'@_undoChore.Name' marked as done</span>
        <button class="btn btn-sm btn-outline-secondary ms-3" @onclick="UndoMarkDone">Undo</button>
    </div>
}

@if (workspaceState.CurrentWorkspace == null)
{
    <div class="text-muted mt-4">Select a workspace from the sidebar to view the calendar.</div>
}
else
{
    <div class="d-flex align-items-start justify-content-between gap-3 mb-3">
        <div>
            <h1 class="page-title">Calendar</h1>
            <p class="text-muted small mb-0">Planned dates &amp; recurring tasks &middot; click an event to mark
                done</p>
            </div>
        </div>

        <RadzenScheduler TItem="CalendarAppointment" Data="@_appointments" StartProperty="@nameof(CalendarAppointment.Start)"
                         EndProperty="@nameof(CalendarAppointment.End)" TextProperty="@nameof(CalendarAppointment.Text)"
                         AppointmentSelect="@OnAppointmentSelect" AppointmentRender="@OnAppointmentRender" Culture="@_culture"
                         Style="height:calc(100vh - 160px)">
            <RadzenWeekView StartTime="@TimeSpan.FromHours(5)" EndTime="@TimeSpan.FromHours(24)" />
            <RadzenMonthView />
            <RadzenDayView StartTime="@TimeSpan.FromHours(5)" EndTime="@TimeSpan.FromHours(24)" />
        </RadzenScheduler>
    }

@code {
    private static readonly System.Globalization.CultureInfo _culture = new("fr-FR");

    private IDictionary<Guid, Chore> _chores = new Dictionary<Guid, Chore>();
    private List<Domain> _domains = [];
    private List<CalendarAppointment> _appointments = [];

    private Chore? _undoChore;
    private List<Domain> _undoDomains = [];
    private System.Threading.Timer? _undoTimer;

    private record CalendarAppointment(string Kind, string Text, DateTime Start, DateTime End, Chore Chore);

    protected override async Task OnInitializedAsync()
    {
        workspaceState.OnChanged += OnWorkspaceChanged;
        await LoadData();
    }

    private async void OnWorkspaceChanged()
    {
        await LoadData();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadData()
    {
        if (workspaceState.CurrentWorkspace?.Id is Guid wsId)
        {
            _chores = await choreService.GetChoresAsync(wsId);
            _domains = await domainRepository.GetDomainsAsync(wsId);
        }
        else
        {
            _chores = new Dictionary<Guid, Chore>();
            _domains = [];
        }
        _appointments = BuildAppointments();
    }

    private List<CalendarAppointment> BuildAppointments()
    {
        var result = new List<CalendarAppointment>();
        foreach (var chore in _chores.Values.Where(c => !c.IsDone))
        {
            if (chore.StartDate.HasValue)
            {
                var startMinutes = chore.StartTime ?? 9 * 60;
                var start = chore.StartDate.Value.ToDateTime(
                    TimeOnly.FromTimeSpan(TimeSpan.FromMinutes(startMinutes)));
                var durationMinutes = chore.Duration.HasValue ? chore.Duration.Value * 15 : 60;
                var end = start.AddMinutes(durationMinutes);

                result.Add(new("start", chore.Name, start, end, chore));
            }

            // Fixed-schedule recurring: add upcoming occurrences for the next 60 days
            if (chore.RecurrenceDaysOfWeek.HasValue && chore.RecurrenceResetTime.HasValue
                && !chore.RecurrenceIntervalHours.HasValue)
            {
                var resetTime = TimeOnly.FromTimeSpan(TimeSpan.FromMinutes(chore.RecurrenceResetTime.Value));
                var today = DateOnly.FromDateTime(DateTime.Today);
                for (int i = 0; i < 60; i++)
                {
                    var day = today.AddDays(i);
                    int bit = ((int)day.DayOfWeek + 6) % 7;
                    if ((chore.RecurrenceDaysOfWeek.Value & (1 << bit)) != 0)
                    {
                        var dt = day.ToDateTime(resetTime);
                        result.Add(new("recur", chore.Name, dt, dt.AddHours(1), chore));
                    }
                }
            }
        }
        return result;
    }

    private async Task OnAppointmentSelect(SchedulerAppointmentSelectEventArgs<CalendarAppointment> args)
    {
        var chore = args.Data.Chore;
        if (chore.IsDone) return;

        await choreService.SetDoneState(chore, _domains, isDone: true, changeDomainsScore: true);
        _appointments = BuildAppointments();

        ShowUndoToast(chore);
    }

    private void ShowUndoToast(Chore chore)
    {
        _undoTimer?.Dispose();
        _undoChore = chore;
        _undoDomains = [.. _domains];

        _undoTimer = new System.Threading.Timer(async _ =>
        {
            _undoChore = null;
            _undoTimer?.Dispose();
            _undoTimer = null;
            await InvokeAsync(StateHasChanged);
        }, null, 5000, System.Threading.Timeout.Infinite);
    }

    private async Task UndoMarkDone()
    {
        if (_undoChore == null) return;

        var chore = _undoChore;
        _undoChore = null;
        _undoTimer?.Dispose();
        _undoTimer = null;

        await choreService.SetDoneState(chore, _undoDomains, isDone: false, changeDomainsScore: true);
        await LoadData();
    }

    private void OnAppointmentRender(SchedulerAppointmentRenderEventArgs<CalendarAppointment> args)
    {
        args.Attributes["style"] = args.Data.Kind switch
        {
            "recur" => "background:#6c3fc4;border-color:#6c3fc4",
            _ => "background:#1565c0;border-color:#1565c0"
        };
    }

    public void Dispose()
    {
        workspaceState.OnChanged -= OnWorkspaceChanged;
        _undoTimer?.Dispose();
    }
}
