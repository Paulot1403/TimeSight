@using Microsoft.AspNetCore.Components.QuickGrid
@using TimeSight.repositories
@using TimeSight.Services
@using System.Security.Claims
@page "/domains"

@attribute [Authorize]
@implements IDisposable
@inject NavigationManager navigationManager
@inject IDomainRepository domainRepository
@inject WorkspaceState workspaceState

<PageTitle>Domains — TimeSight</PageTitle>

@if (workspaceState.CurrentWorkspace == null)
{
    <div class="text-muted mt-4">Select a workspace from the sidebar to view domains.</div>
}
else
{
    <div class="domains-wrap">
        <div class="d-flex align-items-start justify-content-between gap-3 mb-4">
            <div>
                <h1 class="page-title">Domains</h1>
                <p class="text-muted small mb-0">Categories for your tasks</p>
            </div>
            <div class="flex-shrink-0">
                <button type="button" class="btn btn-primary btn-sm" @onclick="AddDomain">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                         stroke-linecap="round">
                        <line x1="12" y1="5" x2="12" y2="19" />
                        <line x1="5" y1="12" x2="19" y2="12" />
                    </svg>
                    New domain
                </button>
            </div>
        </div>

        <div class="border rounded overflow-hidden">
            <QuickGrid Items="domains.AsQueryable()">
                <TemplateColumn Title="Name">
                    <div class="d-flex align-items-center gap-2">
                        <span class="domain-color-dot flex-shrink-0"
                              style="background:@(context.Color ?? "#6366f1")"></span>
                        @context.Name
                    </div>
                </TemplateColumn>
                <PropertyColumn Property="d => d.Importance" Title="Importance" Class="domain-col-importance" />
                <PropertyColumn Property="d => Domain.ComputePriority(d.DoneScore, d.Importance)" Title="Priority" Format="0.##" />
                <PropertyColumn Property="d => d.DoneScore" Title="Done score" Format="0.##" Class="domain-col-donescore" />

                <TemplateColumn Title="" Class="domain-col-icon">
                    @if (!string.IsNullOrWhiteSpace(context.Description))
                    {
                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                @onclick="() => ToggleDescription(context.Id!.Value)"
                                title="@(expandedId == context.Id!.Value ? "Hide description" : "Show description")">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                @if (expandedId == context.Id!.Value)
                                {
                                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94" />
                                    <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19" />
                                    <line x1="1" y1="1" x2="23" y2="23" />
                                }
                                else
                                {
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                    <circle cx="12" cy="12" r="3" />
                                }
                            </svg>
                        </button>
                    }
                </TemplateColumn>
                <TemplateColumn Title="" Class="domain-col-edit">
                    <button type="button" class="btn btn-outline-secondary btn-sm"
                            @onclick="() => EditDomain(context)">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round" class="me-1">
                            <path d="M12 20h9" />
                            <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z" />
                        </svg>
                        <span class="btn-label">Edit</span>
                    </button>
                </TemplateColumn>
                <TemplateColumn Title="" Class="domain-col-delete">
                    <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => DeleteDomain(context)"
                            disabled="@(_deletingId == context.Id)">
                        @if (_deletingId == context.Id)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        }
                        else
                        {
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round" class="me-1">
                                <polyline points="3 6 5 6 21 6" />
                                <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                                <path d="M10 11v6" />
                                <path d="M14 11v6" />
                                <path d="M9 6V4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2" />
                            </svg>
                        }
                        <span class="btn-label">Delete</span>
                    </button>
                </TemplateColumn>
            </QuickGrid>
        </div>

        @if (expandedId is Guid id)
        {
            var domain = domains.FirstOrDefault(d => d.Id == id);
            if (domain is not null)
            {
                <div class="domain-description-panel mt-3 p-3 border rounded">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="domain-color-dot flex-shrink-0" style="background:@(domain.Color ?? "#6366f1")"></span>
                        <strong>@domain.Name</strong>
                    </div>
                    <MarkdownView Value="@domain.Description" />
                </div>
            }
        }
    </div>
}

@code {
    [CascadingParameter]
    public Guid UserId { get; set; }

    private ICollection<Domain> domains = [];
    private Guid? expandedId;
    private Guid? _deletingId;

    protected override async Task OnInitializedAsync()
    {
        workspaceState.OnChanged += OnWorkspaceChanged;
        await LoadDomains();
        await base.OnInitializedAsync();
    }

    private async void OnWorkspaceChanged()
    {
        await LoadDomains();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadDomains()
    {
        if (workspaceState.CurrentWorkspace?.Id is Guid wsId)
            domains = await domainRepository.GetDomainsAsync(wsId);
        else
            domains = [];

        domains = domains.OrderByDescending(d => d.Importance).ToList();
        expandedId = null;
    }

    public void Dispose() => workspaceState.OnChanged -= OnWorkspaceChanged;

    private void ToggleDescription(Guid id)
    {
        expandedId = expandedId == id ? null : id;
    }

    public async Task AddDomain()
    {
        navigationManager.NavigateToRelative("domains/create");
    }

    public async Task DeleteDomain(Domain domain)
    {
        _deletingId = domain.Id;
        try
        {
            if (expandedId == domain.Id)
                expandedId = null;
            await domainRepository.DeleteDomainAsync(domain.Id!.Value);
            domains.Remove(domain);
        }
        finally
        {
            _deletingId = null;
        }
    }

    public async Task EditDomain(Domain domain)
    {
        navigationManager.NavigateToRelative($"domains/edit/{domain.Id}");
    }
}
