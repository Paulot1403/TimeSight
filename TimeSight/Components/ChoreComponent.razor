@using TimeSight.Services
@using TimeSight.repositories
@inject IChoreRepository choreRepository
@inject ChoreDomainService choreDomainService

@if (Chore == null)
{
    <li class="chore-skeleton"></li>
}
else
{
    <li class="chore-card @(Chore.IsDone ? "chore-done" : "") @(Depth > 0 ? "chore-subtask" : "")"
        style="--chore-depth: @Depth"
        @onclick="OpenPanel">
        <div class="chore-inner">

            <div class="chore-check-wrap" @onclick:stopPropagation>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="check-@Chore.Id" checked="@Chore.IsDone"
                           @onchange="ToggleDone" />
                </div>
            </div>

            <div class="chore-body">
                <span class="chore-name">@Chore.Name</span>
                <div class="chore-tags" @onclick:stopPropagation>
                    @foreach (var domain in domainsSelected)
                    {
                        <button type="button" class="domain-tag" @onclick="() => choreDomainService.RemoveLink(Chore, domain)"
                                style="--tag-color:@(domain.Color ?? "#6366f1")">
                            @domain.Name<span class="domain-tag-x">x</span>
                        </button>
                    }
                    <div class="dropdown">
                        <button class="btn-add-domain" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            + domain
                        </button>
                        <ul class="dropdown-menu">
                            @foreach (var domain in domainsNotSelected)
                            {
                                <li><a class="dropdown-item"
                                           @onclick="() => choreDomainService.AddLink(Chore, domain)">@domain.Name</a></li>
                                }
                            </ul>
                        </div>

                    @if (Chore.ParentChoreId == null)
                    {
                        <div class="dropdown" @onclick:stopPropagation>
                            <button class="btn-add-domain" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                + parent
                            </button>
                            <ul class="dropdown-menu">
                                @foreach (var chore in availableParents)
                                {
                                    <li><a class="dropdown-item" @onclick="() => SetParent(chore)">@chore.Name</a></li>
                                }
                            </ul>
                        </div>
                    }
                    else
                    {
                        <button class="btn-unlink-subtask" type="button" title="Unlink from parent" @onclick="UnlinkFromParent" @onclick:stopPropagation>
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <line x1="18" y1="6" x2="6" y2="18" />
                                <line x1="6" y1="6" x2="18" y2="18" />
                            </svg>
                            unlink
                        </button>
                    }
                </div>
            </div>

                <DeleteButton OnDelete="InvokeOnDeleteAsync" />

            </div>

            @if (showPanel)
            {
                <ChoreDetailPanel Chore="Chore" DomainsSelected="domainsSelected" OnClose="ClosePanel"
                                  AllChores="AllChores" OnHierarchyChanged="OnHierarchyChanged" />
            }
        </li>
    }


@code {
    [Parameter]
    public Chore? Chore { get; set; }

    [Parameter]
    public EventCallback<Chore> OnDelete { get; set; }

    [Parameter]
    public EventCallback OnIsDoneChanged { get; set; }

    [Parameter]
    public ICollection<Chore> AllChores { get; set; } = [];

    [Parameter]
    public int Depth { get; set; } = 0;

    [Parameter]
    public EventCallback OnHierarchyChanged { get; set; }

    [Parameter]
    public ICollection<Domain>? allDomains
    {
        get { return field == null ? [] : field; }
        set { field = value; }
    }

    [Parameter]
    public bool StartEditing { get; set; }

    private ICollection<Domain> domainsSelected
    {
        get
        {
            if (Chore == null) return [];
            return [.. allDomains.Where(d => Chore.ChoreDomains.Any(cd => cd.DomainId == d.Id))];
        }
    }

    private ICollection<Domain>? domainsNotSelected
    {
        get
        {
            if (allDomains == null) return [];
            return allDomains.Except(domainsSelected).ToList();
        }
    }

    private IEnumerable<Chore> availableParents
    {
        get
        {
            if (Chore?.Id == null) return [];
            var descendantIds = GetDescendantIds(Chore);
            return AllChores.Where(c =>
                c.Id != Chore.Id &&
                !descendantIds.Contains(c.Id));
        }
    }

    private HashSet<Guid?> GetDescendantIds(Chore chore)
    {
        var ids = new HashSet<Guid?>();
        foreach (var child in AllChores.Where(c => c.ParentChoreId == chore.Id))
        {
            ids.Add(child.Id);
            foreach (var id in GetDescendantIds(child))
                ids.Add(id);
        }
        return ids;
    }

    private bool showPanel = false;

    protected override void OnInitialized()
    {
        if (StartEditing)
            showPanel = true;
    }

    private async Task ToggleDone(ChangeEventArgs e)
    {
        Chore!.IsDone = (bool)e.Value!;
        Chore.DoneAt = Chore.IsDone ? DateTime.UtcNow : null;
        await choreRepository.UpdateChoreAsync(Chore);
        await OnIsDoneChanged.InvokeAsync();
    }

    private async Task InvokeOnDeleteAsync()
    {
        ArgumentNullException.ThrowIfNull(Chore?.Id);
        await OnDelete.InvokeAsync(Chore);
    }

    private async Task SetParent(Chore parent)
    {
        Chore!.ParentChoreId = parent.Id;
        await choreRepository.UpdateChoreAsync(Chore);
        await OnHierarchyChanged.InvokeAsync();
    }

    private async Task UnlinkFromParent()
    {
        Chore!.ParentChoreId = null;
        await choreRepository.UpdateChoreAsync(Chore);
        await OnHierarchyChanged.InvokeAsync();
    }

    private void OpenPanel() => showPanel = true;
    private void ClosePanel() => showPanel = false;
}
