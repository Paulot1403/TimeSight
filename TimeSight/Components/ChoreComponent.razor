@using TimeSight.repositories
@inject IChoreRepository choreRepository

@if (Chore == null)
{
    <li class="chore-skeleton"></li>
}
else
{
    <li class="chore-card">
        <div class="chore-inner">

            <div class="chore-check-wrap">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" value="" id="check-@Chore.Id">
                </div>
            </div>

            <div class="chore-body">
                <span class="chore-name">@Chore.Name</span>
                <div class="chore-tags">
                    @foreach (var domain in domainsSelected)
                    {
                        <button type="button" class="domain-tag" @onclick="() => RemoveLink(Chore, domain)">
                            @domain.Name<span class="domain-tag-x">×</span>
                        </button>
                    }
                    <div class="dropdown">
                        <button class="btn-add-domain" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            + domain
                        </button>
                        <ul class="dropdown-menu">
                            @foreach (var domain in domainsNotSelected)
                            {
                                <li><a class="dropdown-item" @onclick="() => AddLink(Chore, domain)">@domain.Name</a></li>
                            }
                        </ul>
                    </div>
                </div>
            </div>

            <div class="chore-metrics">
                <div class="metric">
                    <span class="metric-label">Impact</span>
                    <div class="metric-row">
                        <span class="metric-val">@Chore.Significance</span>
                        <input type="range" class="form-range" min="1" max="4" @bind="Chore.Significance" @bind:event="oninput" id="sig-@Chore.Id">
                    </div>
                </div>
                <div class="metric">
                    <span class="metric-label">Duration</span>
                    <div class="metric-row">
                        <span class="metric-val">@Chore.Duration</span>
                        <input type="range" class="form-range" min="1" max="4" @bind="Chore.Duration" @bind:event="oninput" id="dur-@Chore.Id">
                    </div>
                </div>
            </div>

            <button class="btn-delete-chore" @onclick="Delete" title="Delete task">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="3 6 5 6 21 6"/>
                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                    <path d="M10 11v6M14 11v6"/>
                    <path d="M9 6V4h6v2"/>
                </svg>
            </button>

        </div>
    </li>
}


@code {
    [Parameter]
    public Chore? Chore { get; set; }

    [Parameter]
    public EventCallback<Chore> OnDelete { get; set; }

    [Parameter]
    public ICollection<Domain>? allDomains { get; set; }
    private ICollection<Domain>? domainsSelected => Chore?.ChoreDomains?.Select(cd => cd.Domain!)?.ToList();
    private ICollection<Domain>? domainsNotSelected => allDomains?.Except(domainsSelected).ToList();


    protected override void OnParametersSet()
    {
        allDomains ??= [];
    }
    public async Task RemoveLink(Chore chore, Domain domain)
    {
        chore.ChoreDomains.RemoveAll(cd => matches(cd, chore, domain));
        await choreRepository.UpdateChoreAsync(chore);
    }
    public async Task AddLink(Chore chore, Domain domain)
    {
        ChoreDomain choreDomain = new ChoreDomain(chore, domain);

        chore.ChoreDomains.Add(choreDomain);
        await choreRepository.UpdateChoreAsync(chore);
    }

    public async Task Delete()
    {
        ArgumentNullException.ThrowIfNull(Chore?.Id);
        await OnDelete.InvokeAsync(Chore);
    }
    private bool matches(ChoreDomain choreDomain, Chore chore, Domain domain)
    {
        return choreDomain.ChoreId == chore.Id.Value && choreDomain.DomainId == domain.Id.Value;
    }
}
