@using TimeSight.Services
@using TimeSight.repositories
@inject ChoreService choreService
@inject ChoreDomainService choreDomainService

@if (Chore == null)
{
    <li class="chore-skeleton"></li>
}
else
{
    <li class="chore-card @(Chore.IsDone ? "chore-done" : "") @(Depth > 0 ? "chore-subtask" : "")"
        style="--chore-depth: @Depth" @onclick="OpenPanel">
        <div class="chore-inner">

            <div class="chore-check-wrap" @onclick:stopPropagation>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="check-@Chore.Id" checked="@Chore.IsDone"
                           @onchange="ToggleDone" disabled="@_isTogglingDone" />
                </div>
            </div>

            <div class="chore-body">
                <span class="chore-name">
                    @Chore.Name
                    @if (Chore.RecurrenceIntervalDays.HasValue)
                    {
                        <svg class="chore-recurrence-icon" width="11" height="11" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                             title="Recurring every @Chore.RecurrenceIntervalDays day@(Chore.RecurrenceIntervalDays == 1 ? "" : "s")">
                            <polyline points="1 4 1 10 7 10" />
                            <polyline points="23 20 23 14 17 14" />
                            <path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4-4.64 4.36A9 9 0 0 1 3.51 15" />
                        </svg>
                    }
                </span>
                <div class="chore-tags" @onclick:stopPropagation>
                    @if (Depth == 0)
                    {
                        @foreach (var domain in DomainsSelected)
                        {
                            <button type="button" class="domain-tag"
                                    disabled="@(Chore.ParentChoreId != null || _busyDomainId == domain.Id)"
                                    @onclick="() => RemoveDomainTag(domain)"
                                    style="--tag-color:@(domain.Color ?? "#6366f1")">
                                @domain.Name
                                @if (Chore.ParentChoreId == null)
                                {
                                    <span class="domain-tag-x">@(_busyDomainId == domain.Id ? "…" : "x")</span>
                                }
                            </button>
                        }
                    }

                    @if (Chore.ParentChoreId == null)
                    {
                        <div class="dropdown">
                            <button class="btn-add-domain" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                + domain
                            </button>
                            <ul class="dropdown-menu">
                                @foreach (var domain in DomainsNotSelected)
                                {
                                    <li><a class="dropdown-item @(_addingDomain ? "disabled" : "")"
                                               @onclick="() => AddDomainTag(domain)">@domain.Name</a></li>
                                    }
                                </ul>
                            </div>
                        }

                    </div>
                </div>

                @if (Chore.Children.Count == 0)
                {
                    <DeleteButton OnDelete="InvokeOnDeleteAsync" />
                }

            </div>

            @if (showPanel)
            {
                <ChoreDetailPanel Chore="Chore" DomainsSelected="DomainsSelected" AllDomains="allDomains" OnClose="ClosePanel"
                                  AllChores="AllChores" OnHierarchyChanged="OnHierarchyChanged" />
            }
        </li>
    }


@code {
    [Parameter]
    public Chore? Chore { get; set; }

    [Parameter]
    public ICollection<Domain>? allDomains
    {
        get { return field == null ? [] : field; }
        set { field = value; }
    }

    [Parameter]
    public bool StartEditing { get; set; }
    [Parameter]
    public int Depth { get; set; } = 0;
    [Parameter]
    public EventCallback<Chore> OnDelete { get; set; }

    [Parameter]
    public EventCallback OnIsDoneChanged { get; set; }

    [Parameter]
    public EventCallback OnHierarchyChanged { get; set; }

    [Parameter]
    public ICollection<Chore> AllChores { get; set; } = [];

  
    private ICollection<Domain> DomainsSelected
    {
        get
        {
            if (Chore == null) return [];
            var source = Chore.GetRootOfThis();
            return [.. allDomains.Where(d => source.ChoreDomains.Any(cd => cd.DomainId == d.Id))];
        }
    }

    private ICollection<Domain>? DomainsNotSelected
    {
        get
        {
            if (allDomains == null) return [];
            return allDomains.Except(DomainsSelected).ToList();
        }
    }

    private IEnumerable<Chore> AvailableParents
    {
        get
        {
            if (Chore?.Id == null) return [];
            var descendantIds = GetDescendantIds(Chore);
            return AllChores.Where(c =>
                c.Id != Chore.Id &&
                !descendantIds.Contains(c.Id));
        }
    }

    private HashSet<Guid?> GetDescendantIds(Chore chore)
    {
        var ids = new HashSet<Guid?>();
        foreach (var child in AllChores.Where(c => c.ParentChoreId == chore.Id))
        {
            ids.Add(child.Id);
            foreach (var id in GetDescendantIds(child))
                ids.Add(id);
        }
        return ids;
    }

    private bool showPanel = false;
    private bool _isTogglingDone;
    private Guid? _busyDomainId;
    private bool _addingDomain;

    protected override void OnInitialized()
    {
        if (StartEditing)
            showPanel = true;
    }

    private async Task ToggleDone(ChangeEventArgs e)
    {
        bool isDone = (bool)e.Value!;
        _isTogglingDone = true;
        try
        {
            await choreService.SetDoneState(Chore!, allDomains!, isDone);
        }
        finally
        {
            _isTogglingDone = false;
        }
        await OnIsDoneChanged.InvokeAsync();
    }

    private async Task RemoveDomainTag(Domain domain)
    {
        _busyDomainId = domain.Id;
        try
        {
            await choreDomainService.RemoveLink(Chore!, domain);
        }
        finally
        {
            _busyDomainId = null;
        }
    }

    private async Task AddDomainTag(Domain domain)
    {
        _addingDomain = true;
        try
        {
            await choreDomainService.AddLink(Chore!, domain);
        }
        finally
        {
            _addingDomain = false;
        }
    }

    private async Task InvokeOnDeleteAsync()
    {
        ArgumentNullException.ThrowIfNull(Chore?.Id);
        await OnDelete.InvokeAsync(Chore);
    }

    private async Task SetParent(Chore parent)
    {
        await choreService.SetParent(Chore!, parent, allDomains);
        await OnHierarchyChanged.InvokeAsync();
    }

    private async Task UnlinkFromParent()
    {
        await choreService.RemoveParent(Chore!, allDomains);
        await OnHierarchyChanged.InvokeAsync();
    }

    private void OpenPanel() => showPanel = true;
    private void ClosePanel() => showPanel = false;
}
