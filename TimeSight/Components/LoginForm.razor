@using System.ComponentModel.DataAnnotations
@using Supabase.Gotrue;
@using TimeSight.SupabaseClient.Models

@inject SupabaseAuthService authService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="login-page">
    <div class="login-card">

        <div class="login-brand">
            <div class="login-brand-mark">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round">
                    <circle cx="12" cy="12" r="9"/>
                    <polyline points="12 7 12 12 15.5 15.5"/>
                </svg>
            </div>
            <span class="login-brand-name">TimeSight</span>
        </div>

        <h1 class="login-heading">Welcome back</h1>
        <p class="login-sub">Sign in to your workspace</p>

        <button @onclick="SignInWithGithub" disabled="@_loading" class="btn-oauth">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            Continue with GitHub
        </button>

        <div class="login-divider">or</div>

        <EditForm Model="@_model" OnValidSubmit="SignIn">
            <DataAnnotationsValidator />

            @if (_error is not null)
            {
                <p class="login-error">@_error</p>
            }

            <div class="form-group">
                <label for="login-email">Email</label>
                <InputText class="form-control" id="login-email" @bind-Value="_model.Email" type="email" placeholder="you@example.com" />
                <ValidationMessage For="() => _model.Email" />
            </div>

            <div class="form-group">
                <label for="login-password">Password</label>
                <InputText class="form-control" id="login-password" @bind-Value="_model.Password" type="password" placeholder="••••••••" />
                <ValidationMessage For="() => _model.Password" />
            </div>

            <button type="submit" disabled="@_loading" class="btn btn-primary btn-full">
                @(_loading ? "Signing in…" : "Sign in")
            </button>
        </EditForm>

    </div>
</div>

@code {
    private readonly LoginModel _model = new();
    private string? _error;
    private bool _loading;

    private async Task SignIn()
    {
        _error = null;
        _loading = true;
        try
        {
            await authService.SignInAsync(_model.Email, _model.Password);
            Navigation.NavigateTo("/");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SignInWithGithub()
    {
        _error = null;
        _loading = true;
        try
        {
            SignInInfo? signInInfo = await authService.GetSignInInfoForProviderAsync(
                    Constants.Provider.Github,
                     Navigation.BaseUri + "authentication/callback");


            if (signInInfo.SignInUri is not null)
            {
                if (signInInfo.PKCEVerifier is not null)
                    await JS.InvokeVoidAsync("sessionStorage.setItem", "pkce_verifier", signInInfo.PKCEVerifier);

                Navigation.NavigateTo(signInInfo.SignInUri.ToString(), forceLoad: true);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _loading = false;
        }
    }

    private class LoginModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        public string Password { get; set; } = "";
    }
}
