@using System.ComponentModel.DataAnnotations
@using Supabase.Gotrue;
@using TimeSight.SupabaseClient.Models

@inject SupabaseAuthService authService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="login-page min-vh-100 d-flex align-items-center justify-content-center">
    <div class="card login-card">
        <div class="card-body p-4">

            <div class="d-flex align-items-center gap-2 mb-4">
                <div class="login-brand-mark">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round">
                        <circle cx="12" cy="12" r="9"/>
                        <polyline points="12 7 12 12 15.5 15.5"/>
                    </svg>
                </div>
                <span class="login-brand-name">TimeSight</span>
            </div>

            <h1 class="h4 fw-bold mb-1">Welcome back</h1>
            <p class="text-muted small mb-4">Sign in to your workspace</p>

            <button @onclick="SignInWithMicrosoft" disabled="@_loading"
                    class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-2">
                <svg width="16" height="16" viewBox="0 0 23 23" aria-hidden="true" fill="currentColor">
                    <rect x="1" y="1" width="10" height="10" fill="#F25022"/>
                    <rect x="12" y="1" width="10" height="10" fill="#7FBA00"/>
                    <rect x="1" y="12" width="10" height="10" fill="#00A4EF"/>
                    <rect x="12" y="12" width="10" height="10" fill="#FFB900"/>
                </svg>
                Continue with Microsoft
            </button>

            <div class="login-divider my-3">or</div>

            <EditForm Model="@_model" OnValidSubmit="SignIn">
                <DataAnnotationsValidator />

                @if (_error is not null)
                {
                    <div class="alert alert-danger py-2 small">@_error</div>
                }

                <div class="mb-3">
                    <label class="form-label" for="login-email">Email</label>
                    <InputText class="form-control" id="login-email" @bind-Value="_model.Email" type="email" placeholder="you@example.com" />
                    <ValidationMessage For="() => _model.Email" />
                </div>

                <div class="mb-3">
                    <label class="form-label" for="login-password">Password</label>
                    <InputText class="form-control" id="login-password" @bind-Value="_model.Password" type="password" placeholder="••••••••" />
                    <ValidationMessage For="() => _model.Password" />
                </div>

                <button type="submit" disabled="@_loading" class="btn btn-primary w-100 mt-1">
                    @(_loading ? "Signing in…" : "Sign in")
                </button>
            </EditForm>

        </div>
    </div>
</div>

@code {
    private readonly LoginModel _model = new();
    private string? _error;
    private bool _loading;

    private async Task SignIn()
    {
        _error = null;
        _loading = true;
        try
        {
            await authService.SignInAsync(_model.Email, _model.Password);
            Navigation.NavigateTo(Navigation.BaseUri);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SignInWithMicrosoft()
    {
        _error = null;
        _loading = true;
        try
        {
            // Scopes must also be configured in the Supabase dashboard under Auth > Providers > Azure
            SignInInfo? signInInfo = await authService.GetSignInInfoForProviderAsync(
                Constants.Provider.Azure,
                Navigation.BaseUri + "authentication/callback",
                "Calendars.ReadWrite offline_access");

            if (signInInfo.SignInUri is not null)
            {
                bool popupBlocked = false;
                try
                {
                    await JS.InvokeVoidAsync("oauthPopup.open",
                        signInInfo.SignInUri.ToString(),
                        signInInfo.PKCEVerifier ?? "");
                }
                catch (JSException ex) when (ex.Message.Contains("popup_blocked"))
                {
                    popupBlocked = true;
                }

                if (popupBlocked)
                {
                    // Popup was blocked: fall back to full-page redirect.
                    await JS.InvokeVoidAsync("localStorage.setItem", "pkce_verifier", signInInfo.PKCEVerifier ?? "");
                    Navigation.NavigateTo(signInInfo.SignInUri.ToString(), forceLoad: true);
                    return;
                }

                await authService.ReloadSessionAsync();
                Navigation.NavigateTo(Navigation.BaseUri);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _loading = false;
        }
    }

    private class LoginModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        public string Password { get; set; } = "";
    }
}
