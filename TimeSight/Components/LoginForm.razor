@using System.ComponentModel.DataAnnotations
@using Supabase.Gotrue;
@using TimeSight.SupabaseClient.Models

@inject SupabaseAuthService authService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<h2>Connexion</h2>

<EditForm Model="@_model" OnValidSubmit="SignIn">
    <DataAnnotationsValidator />
    <div>
        <label>Email</label>
        <InputText @bind-Value="_model.Email" type="email" />
        <ValidationMessage For="() => _model.Email" />
    </div>
    <div>
        <label>Mot de passe</label>
        <InputText @bind-Value="_model.Password" type="password" />
        <ValidationMessage For="() => _model.Password" />
    </div>
    @if (_error is not null)
    {
        <p style="color:red">@_error</p>
    }
    <button type="submit" disabled="@_loading">
        @(_loading ? "Connexion..." : "Se connecter")
    </button>
</EditForm>

<hr />

<button @onclick="SignInWithGithub" disabled="@_loading">
    Se connecter avec GitHub
</button>

@code {
    private readonly LoginModel _model = new();
    private string? _error;
    private bool _loading;

    private async Task SignIn()
    {
        _error = null;
        _loading = true;
        try
        {
            await authService.SignIn(_model.Email, _model.Password);
            Navigation.NavigateTo("/");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SignInWithGithub()
    {
        _error = null;
        _loading = true;
        try
        {
            SignInInfo? signInInfo = await authService.GetSignInInfoForProvider(
                    Constants.Provider.Github,
                     Navigation.BaseUri + "authentication/callback");

            
            if (signInInfo.SignInUri is not null)
            {
                if (signInInfo.PKCEVerifier is not null)
                    await JS.InvokeVoidAsync("sessionStorage.setItem", "pkce_verifier", signInInfo.PKCEVerifier);

                Navigation.NavigateTo(signInInfo.SignInUri.ToString(), forceLoad: true);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _loading = false;
        }
    }

    private class LoginModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        public string Password { get; set; } = "";
    }
}
