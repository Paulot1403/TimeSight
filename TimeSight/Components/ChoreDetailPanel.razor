@using TimeSight.Services
@using TimeSight.repositories
@inject ChoreService choreService
@inject IChoreDomainRepository choreDomainRepository
@inject ChoreDomainService choreDomainService
@inject IJSRuntime JS

<div class="chore-panel-backdrop" @onclick="OnClose" @onclick:stopPropagation></div>
<div class="chore-panel" @onclick:stopPropagation>
    <div class="chore-panel-header">
        <span class="chore-panel-title">Task details</span>
        <button class="chore-panel-close" @onclick="OnClose" title="Close">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
        </button>
    </div>

    <div class="chore-panel-body">
        <div class="mb-4">
            <label class="form-label">Name</label>
            <input class="form-control" @bind="editName" @bind:event="oninput" @ref="nameInputRef" />
        </div>



        @if (!Subtasks.Any())
        {
            <div class="mb-4">

                <div class="d-flex align-items-center gap-2 mb-2">
                    <label class="form-label mb-0">Duration</label>
                    <span class="panel-metric-val">@TimeSight.Models.Chore.DurationLabel(editDuration)</span>
                    <div class="form-check form-switch ms-auto mb-0">
                        <input class="form-check-input" type="checkbox" id="noDurationCheck"
                               checked="@(editDuration == null)" @onchange="e => editDuration = (bool)e.Value! ? null : 2" />
                        <label class="form-check-label small" for="noDurationCheck">No estimate</label>
                    </div>
                </div>
                @if (editDuration.HasValue)
                {
                    <input type="range" class="panel-range" min="1" max="@TimeSight.Models.Chore.MAX_DURATION"
                           value="@editDuration" @oninput="e => editDuration = int.Parse(e.Value!.ToString()!)" />
                    <div class="panel-range-labels">
                        <span>5 min</span>
                        <span>15 min</span>
                        <span>45 min</span>
                        <span>2 h</span>
                    </div>
                }
            </div>
        }
        @if (!Chore.IsSubtask)
        {
            <div class="mb-4">
                <label class="form-label">Importance for Domains</label>
                @foreach (var domain in LocalDomainsSelected)
                {
                    <div class="domain-intensity-row">
                        <div class="d-flex align-items-center gap-2 flex-shrink-0">
                            <button class="panel-subtask-remove" title="Remove domain" @onclick="() => RemoveDomain(domain)"
                                    disabled="@_isBusy">
                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="18" y1="6" x2="6" y2="18" />
                                    <line x1="6" y1="6" x2="18" y2="18" />
                                </svg>
                            </button>
                            <span class="domain-intensity-name" style="--tag-color:@(domain.Color ?? "#6366f1")">
                                @domain.Name
                            </span>
                        </div>
                        <div class="domain-intensity-control">
                            <div class="d-flex align-items-center gap-2">
                                <input type="range" class="panel-range flex-grow-1" min="1"
                                       max="@Math.Max(ChoreDomain.MAXIMUM_LINK_INTENSITY, GetIntensity(domain))" value="@GetIntensity(domain)"
                                       @oninput="e => SetIntensity(domain, e)" />
                                <input type="number" class="panel-intensity-number" min="1" value="@GetIntensity(domain)"
                                       @oninput="e => SetIntensityFromNumber(domain, e)" />
                            </div>
                            <div class="panel-range-labels">
                                <span>Negligible</span>
                                <span>Essential</span>
                            </div>
                        </div>
                    </div>
                }
                @if (LocalDomainsNotSelected.Any())
                {
                    <div class="dropdown mt-2">
                        <button class="btn-add-domain" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            + domain
                        </button>
                        <ul class="dropdown-menu">
                            @foreach (var domain in LocalDomainsNotSelected)
                            {
                                <li><a class="dropdown-item @(_isBusy ? "disabled" : "")"
                                           @onclick="() => AddDomain(domain)">@domain.Name</a></li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            }
            <div class="mb-4">
                <label class="form-label">Parent task</label>
                @if (parentChore != null)
                {
                    <div class="panel-subtask-row">
                        <span class="panel-subtask-name">@parentChore.Name</span>
                        <button class="panel-subtask-remove" title="Remove parent link" @onclick="RemoveParent"
                                disabled="@_isBusy">
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <line x1="18" y1="6" x2="6" y2="18" />
                                <line x1="6" y1="6" x2="18" y2="18" />
                            </svg>
                        </button>
                    </div>
                }
                else
                {
                    <div class="dropdown mt-1">
                        <button class="btn-add-domain" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            + parent
                        </button>
                        <ul class="dropdown-menu">
                            @foreach (var chore in availableParents)
                            {
                                <li><a class="dropdown-item @(_isBusy ? "disabled" : "")"
                                           @onclick="() => SetParent(chore)">@chore.Name</a></li>
                                }
                            </ul>
                        </div>
                    }
                </div>

                @if (Subtasks.Any())
                {
                    <div class="mb-4">
                        <label class="form-label">Subtasks</label>
                        @foreach (var sub in Subtasks)
                        {
                            <div class="panel-subtask-row">
                                <span class="panel-subtask-name">@sub.Name</span>
                                <button class="panel-subtask-remove" title="Remove subtask link" @onclick="() => RemoveSubtask(sub)"
                                        disabled="@_isBusy">
                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                                         stroke-linecap="round" stroke-linejoin="round">
                                        <line x1="18" y1="6" x2="6" y2="18" />
                                        <line x1="6" y1="6" x2="18" y2="18" />
                                    </svg>
                                </button>
                            </div>
                        }
                    </div>
                }

            
                <div class="mb-4">
                    <div class="d-flex align-items-center justify-content-between mb-1">
                        <label class="form-label mb-0">Description</label>
                        <div class="btn-group btn-group-sm">
                            <button type="button" class="btn @(descriptionPreview ? "btn-outline-secondary" : "btn-secondary")"
                                    @onclick='() => descriptionPreview = false'>Write</button>
                            <button type="button" class="btn @(descriptionPreview ? "btn-secondary" : "btn-outline-secondary")"
                                    @onclick='() => descriptionPreview = true'>Preview</button>
                        </div>
                    </div>
                    @if (descriptionPreview)
                    {
                        <div class="panel-markdown-preview">
                            @if (string.IsNullOrWhiteSpace(editDescription))
                            {
                                <span class="text-muted fst-italic" style="font-size:0.85rem">No description.</span>
                            }
                            else
                            {
                                <MarkdownView Value="@editDescription" />
                            }
                        </div>
                    }
                    else
                    {
                        <textarea class="form-control" rows="4" placeholder="Markdown supported…" @bind="editDescription"
                                  @bind:event="oninput"></textarea>
                    }
                </div>
                <div class="mb-4">
                    <label class="form-label">Recurrence</label>
                    <div class="d-flex gap-3 mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="recurrenceMode" id="recNone"
                                   checked="@(editRecurrenceMode == "none")"
                                   @onclick='() => SetRecurrenceMode("none")' />
                            <label class="form-check-label" for="recNone">None</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="recurrenceMode" id="recInterval"
                                   checked="@(editRecurrenceMode == "interval")"
                                   @onclick='() => SetRecurrenceMode("interval")' />
                            <label class="form-check-label" for="recInterval">After interval</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="recurrenceMode" id="recSchedule"
                                   checked="@(editRecurrenceMode == "schedule")"
                                   @onclick='() => SetRecurrenceMode("schedule")' />
                            <label class="form-check-label" for="recSchedule">Fixed schedule</label>
                        </div>
                    </div>
                    @if (editRecurrenceMode == "interval")
                    {
                        <select class="form-control" @bind="editRecurrenceStr">
                            <option value="1">Every day</option>
                            <option value="3">Every 3 days</option>
                            <option value="7">Every week</option>
                            <option value="14">Every 2 weeks</option>
                            <option value="30">Every month</option>
                            <option value="60">Every 2 months</option>
                        </select>
                    }
                    @if (editRecurrenceMode == "schedule")
                    {
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <input type="time" class="form-control" style="width:auto"
                                   value="@editResetTime"
                                   @onchange="e => editResetTime = e.Value?.ToString() is { Length: > 0 } v ? v : null" />
                        </div>
                        <div class="d-flex gap-3 flex-wrap mt-1">
                            @foreach (var (label, bit) in DaysOfWeekOptions)
                            {
                                <div class="form-check form-check-inline mb-0">
                                    <input class="form-check-input" type="checkbox" id="dow-@bit"
                                           checked="@((editDaysOfWeek & bit) != 0)"
                                           @onchange="e => ToggleDay(bit, (bool)e.Value!)" />
                                    <label class="form-check-label small" for="dow-@bit">@label</label>
                                </div>
                            }
                        </div>
                    }
                </div>

            </div>

            <div class="chore-panel-footer">
                <button class="btn btn-primary" @onclick="Save" disabled="@(_isSaving || _isBusy)">
                    @if (_isSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    @(_isSaving ? "Saving…" : "Save")
                </button>
                <button class="btn btn-outline-secondary" @onclick="OnClose" disabled="@_isSaving">Cancel</button>
            </div>
        </div>

@code {
    [Parameter, EditorRequired] public Chore? Chore { get; set; }
    [Parameter] public ICollection<Domain> DomainsSelected { get; set; } = [];
    [Parameter] public ICollection<Domain> AllDomains { get; set; } = [];
    [Parameter] public ICollection<Chore> AllChores { get; set; } = [];
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnHierarchyChanged { get; set; }

    private ICollection<Domain> LocalDomainsSelected =>
        Chore == null ? [] : [.. AllDomains.Where(d => Chore.ChoreDomains.Any(cd => cd.DomainId == d.Id))];

    private ICollection<Domain> LocalDomainsNotSelected =>
        [.. AllDomains.Except(LocalDomainsSelected)];

    private ElementReference nameInputRef;
    private bool _shouldFocus = false;
    private bool _isSaving;
    private bool _isBusy;
    private string editName = string.Empty;
    private string? editDescription;
    private bool descriptionPreview = false;
    private int? editDuration;
    private int? editRecurrenceIntervalDays;
    private string editRecurrenceStr
    {
        get => editRecurrenceIntervalDays?.ToString() ?? "0";
        set => editRecurrenceIntervalDays = value == "0" ? null : int.Parse(value);
    }
    private string editRecurrenceMode = "none";
    private string? editResetTime;
    private int editDaysOfWeek = 127;

    private static readonly (string label, int bit)[] DaysOfWeekOptions =
        [("Mon", 1), ("Tue", 2), ("Wed", 4), ("Thu", 8), ("Fri", 16), ("Sat", 32), ("Sun", 64)];

    private void SetRecurrenceMode(string mode)
    {
        editRecurrenceMode = mode;
        if (mode != "interval")
            editRecurrenceIntervalDays = null;
        if (mode != "schedule")
        {
            editResetTime = null;
            editDaysOfWeek = 127;
        }
        if (mode == "interval" && editRecurrenceIntervalDays == null)
            editRecurrenceIntervalDays = 1;
    }

    private void ToggleDay(int bit, bool value)
    {
        if (value) editDaysOfWeek |= bit;
        else editDaysOfWeek &= ~bit;
    }

    private Dictionary<Guid, int> intensities = [];


    private Chore? parentChore =>
        Chore?.ParentChoreId != null
            ? AllChores.FirstOrDefault(c => c.Id == Chore.ParentChoreId)
            : null;

    private IEnumerable<Chore> Subtasks =>
        Chore?.Id != null
            ? Chore.Children
            : [];

    private IEnumerable<Chore> availableParents
    {
        get
        {
            if (Chore?.Id == null) return [];
            var descendantIds = GetDescendantIds(Chore);
            return AllChores.Where(c =>
                c.Id != Chore.Id &&
                !descendantIds.Contains(c.Id));
        }
    }

    private HashSet<Guid?> GetDescendantIds(Chore chore)
    {
        var ids = new HashSet<Guid?>();
        foreach (var child in AllChores.Where(c => c.ParentChoreId == chore.Id))
        {
            ids.Add(child.Id);
            foreach (var id in GetDescendantIds(child))
                ids.Add(id);
        }
        return ids;
    }

    protected override void OnInitialized()
    {
        editName = Chore?.Name ?? string.Empty;
        editDescription = Chore?.Description;
        editDuration = Subtasks.Any() ? null : Chore?.Duration;
        editRecurrenceIntervalDays = Chore?.RecurrenceIntervalDays;
        editDaysOfWeek = Chore?.RecurrenceDaysOfWeek ?? 127;
        editResetTime = Chore?.RecurrenceResetTime is { } t
            ? $"{t / 60:D2}:{t % 60:D2}"
            : null;
        editRecurrenceMode = Chore?.RecurrenceResetTime.HasValue == true ? "schedule"
            : Chore?.RecurrenceIntervalDays.HasValue == true ? "interval"
            : "none";

        intensities = Chore?.ChoreDomains
            .ToDictionary(cd => cd.DomainId, cd => cd.LinkIntensity) ?? [];
        _shouldFocus = true;
    }


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldFocus)
        {
            _shouldFocus = false;
            await JS.InvokeVoidAsync("blazorHelpers.focusAndSelect", nameInputRef);
        }
    }

    private int GetIntensity(Domain domain) =>
        intensities.TryGetValue(domain.Id!.Value, out var v) ? v : ChoreDomain.DEFAULT_LINK_INTENSITY;

    private void SetIntensity(Domain domain, ChangeEventArgs e) =>
        intensities[domain.Id!.Value] = int.Parse(e.Value!.ToString()!);

    private void SetIntensityFromNumber(Domain domain, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v) && v >= 1)
            intensities[domain.Id!.Value] = v;
    }

    private async Task AddDomain(Domain domain)
    {
        _isBusy = true;
        try
        {
            await choreDomainService.AddLink(Chore!, domain);
            intensities[domain.Id!.Value] = ChoreDomain.DEFAULT_LINK_INTENSITY;
        }
        finally { _isBusy = false; }
    }

    private async Task RemoveDomain(Domain domain)
    {
        _isBusy = true;
        try
        {
            await choreDomainService.RemoveLink(Chore!, domain);
            intensities.Remove(domain.Id!.Value);
        }
        finally { _isBusy = false; }
    }

    private async Task SetParent(Chore parent)
    {
        ArgumentNullException.ThrowIfNull(Chore);
        _isBusy = true;
        try
        {
            await choreService.SetParent(Chore, parent, AllDomains);
            await OnHierarchyChanged.InvokeAsync();
        }
        finally { _isBusy = false; }
    }

    private async Task RemoveSubtask(Chore child)
    {
        _isBusy = true;
        try
        {
            await choreService.RemoveParent(child, AllDomains);
            await OnHierarchyChanged.InvokeAsync();
        }
        finally { _isBusy = false; }
    }

    private async Task RemoveParent()
    {
        ArgumentNullException.ThrowIfNull(Chore);
        _isBusy = true;
        try
        {
            await choreService.RemoveParent(Chore, AllDomains);
            await OnHierarchyChanged.InvokeAsync();
        }
        finally { _isBusy = false; }
    }

    private async Task Save()
    {
        _isSaving = true;
        try
        {
            bool choreChanged = false;
            var trimmed = editName.Trim();
            if (!string.IsNullOrEmpty(trimmed) && trimmed != Chore!.Name)
            {
                Chore.Name = trimmed;
                choreChanged = true;
            }
            if (editDuration != Chore!.Duration)
            {
                Chore.Duration = editDuration;
                choreChanged = true;
            }
            if (editDescription != Chore!.Description)
            {
                Chore.Description = editDescription;
                choreChanged = true;
            }
            if (editRecurrenceIntervalDays != Chore!.RecurrenceIntervalDays)
            {
                Chore.RecurrenceIntervalDays = editRecurrenceIntervalDays;
                choreChanged = true;
            }
            int? newResetTime = null;
            int? newDaysOfWeek = null;
            if (editResetTime is not null)
            {
                var parts = editResetTime.Split(':');
                newResetTime = int.Parse(parts[0]) * 60 + int.Parse(parts[1]);
                newDaysOfWeek = editDaysOfWeek == 127 ? null : editDaysOfWeek;
            }
            if (newResetTime != Chore!.RecurrenceResetTime || newDaysOfWeek != Chore.RecurrenceDaysOfWeek)
            {
                Chore.RecurrenceResetTime = newResetTime;
                Chore.RecurrenceDaysOfWeek = newDaysOfWeek;
                choreChanged = true;
            }
            if (choreChanged)
                await choreService.UpdateChoreAsync(Chore);

            if (!Chore.IsSubtask)
            {
                foreach (var cd in Chore!.ChoreDomains)
                {
                    if (intensities.TryGetValue(cd.DomainId, out var newIntensity) && newIntensity != cd.LinkIntensity)
                    {
                        cd.LinkIntensity = newIntensity;
                        await choreDomainRepository.UpdateChoreDomainAsync(cd);
                    }
                }
            }
        }
        finally
        {
            _isSaving = false;
        }

        await OnClose.InvokeAsync();
    }
}
