@using TimeSight.repositories
@inject IChoreRepository choreRepository
@inject IChoreDomainRepository choreDomainRepository
@inject IJSRuntime JS

<div class="chore-panel-backdrop" @onclick="OnClose" @onclick:stopPropagation></div>
<div class="chore-panel" @onclick:stopPropagation>
    <div class="chore-panel-header">
        <span class="chore-panel-title">Task details</span>
        <button class="chore-panel-close" @onclick="OnClose" title="Close">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
        </button>
    </div>

    <div class="chore-panel-body">
        <div class="mb-4">
            <label class="form-label">Name</label>
            <input class="form-control" @bind="editName" @bind:event="oninput" @ref="nameInputRef" />
        </div>

        <div class="mb-4">
            <div class="d-flex align-items-center justify-content-between mb-1">
                <label class="form-label mb-0">Description</label>
                <div class="btn-group btn-group-sm">
                    <button type="button" class="btn @(descriptionPreview ? "btn-outline-secondary" : "btn-secondary")"
                            @onclick='() => descriptionPreview = false'>Write</button>
                    <button type="button" class="btn @(descriptionPreview ? "btn-secondary" : "btn-outline-secondary")"
                            @onclick='() => descriptionPreview = true'>Preview</button>
                </div>
            </div>
            @if (descriptionPreview)
            {
                <div class="panel-markdown-preview">
                    @if (string.IsNullOrWhiteSpace(editDescription))
                    {
                        <span class="text-muted fst-italic" style="font-size:0.85rem">No description.</span>
                    }
                    else
                    {
                        <MarkdownView Value="@editDescription" />
                    }
                </div>
            }
            else
            {
                <textarea class="form-control" rows="4" placeholder="Markdown supported…"
                          @bind="editDescription" @bind:event="oninput"></textarea>
            }
        </div>

        <div class="mb-4">
            <label class="form-label">Duration -- <span class="panel-metric-val">@editDuration</span></label>
            <input type="range" class="panel-range" min="1" max="@TimeSight.Models.Chore.MAX_DURATION"
                   @bind="editDuration" @bind:event="oninput" />
            <div class="panel-range-labels">
                <span>Quick</span>
                <span>Long</span>
            </div>
        </div>

        @if (DomainsSelected.Any())
        {
            <div class="mb-2">
                <label class="form-label">Domain intensity</label>
                @foreach (var domain in DomainsSelected)
                {
                    <div class="domain-intensity-row">
                        <span class="domain-intensity-name" style="--tag-color:@(domain.Color ?? "#6366f1")">
                            @domain.Name
                        </span>
                        <div class="domain-intensity-control">
                            <input type="range" class="panel-range" min="1" max="5"
                                   value="@GetIntensity(domain)"
                                   @oninput="e => SetIntensity(domain, e)" />
                            <span class="panel-metric-val">@GetIntensity(domain)</span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="chore-panel-footer">
        <button class="btn btn-primary" @onclick="Save">Save</button>
        <button class="btn btn-outline-secondary" @onclick="OnClose">Cancel</button>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public Chore? Chore { get; set; }
    [Parameter] public ICollection<Domain> DomainsSelected { get; set; } = [];
    [Parameter] public EventCallback OnClose { get; set; }

    private ElementReference nameInputRef;
    private bool _shouldFocus = false;
    private string editName = string.Empty;
    private string? editDescription;
    private bool descriptionPreview = false;
    private int editDuration;
    private Dictionary<Guid, int> intensities = [];

    protected override void OnInitialized()
    {
        editName = Chore?.Name ?? string.Empty;
        editDescription = Chore?.Description;
        editDuration = Chore?.Duration ?? 1;
        intensities = Chore?.ChoreDomains
            .ToDictionary(cd => cd.DomainId, cd => cd.LinkIntensity) ?? [];
        _shouldFocus = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldFocus)
        {
            _shouldFocus = false;
            await JS.InvokeVoidAsync("blazorHelpers.focusAndSelect", nameInputRef);
        }
    }

    private int GetIntensity(Domain domain) =>
        intensities.TryGetValue(domain.Id!.Value, out var v) ? v : 1;

    private void SetIntensity(Domain domain, ChangeEventArgs e) =>
        intensities[domain.Id!.Value] = int.Parse(e.Value!.ToString()!);

    private async Task Save()
    {
        bool choreChanged = false;
        var trimmed = editName.Trim();
        if (!string.IsNullOrEmpty(trimmed) && trimmed != Chore!.Name)
        {
            Chore.Name = trimmed;
            choreChanged = true;
        }
        if (editDuration != Chore!.Duration)
        {
            Chore.Duration = editDuration;
            choreChanged = true;
        }
        if (editDescription != Chore!.Description)
        {
            Chore.Description = editDescription;
            choreChanged = true;
        }
        if (choreChanged)
            await choreRepository.UpdateChoreAsync(Chore);

        foreach (var cd in Chore!.ChoreDomains)
        {
            if (intensities.TryGetValue(cd.DomainId, out var newIntensity) && newIntensity != cd.LinkIntensity)
            {
                cd.LinkIntensity = newIntensity;
                await choreDomainRepository.UpdateChoreDomainAsync(cd);
            }
        }

        await OnClose.InvokeAsync();
    }
}